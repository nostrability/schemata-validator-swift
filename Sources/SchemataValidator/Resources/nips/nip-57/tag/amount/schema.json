{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "allOf": [
        {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": false
        }
      ]
    },
    {
      "type": "array",
      "minItems": 2,
      "items": [
        {
          "const": "amount"
        },
        {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Amount in millisats, as a decimal string"
        }
      ],
      "additionalItems": false
    }
  ],
  "$id": "https://nostrability.github.io/schemata/tag/amount.json"
}