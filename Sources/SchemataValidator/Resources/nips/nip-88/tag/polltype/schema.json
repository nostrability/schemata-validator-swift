{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "allOf": [
        {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": false
        }
      ]
    },
    {
      "type": "array",
      "minItems": 2,
      "items": [
        {
          "const": "polltype"
        },
        {
          "type": "string",
          "enum": [
            "singlechoice",
            "multiplechoice"
          ]
        }
      ],
      "additionalItems": false,
      "errorMessage": {
        "items": "polltype tag must be ['polltype', 'singlechoice'|'multiplechoice']"
      }
    }
  ],
  "$id": "https://nostrability.github.io/schemata/tag/polltype.json"
}