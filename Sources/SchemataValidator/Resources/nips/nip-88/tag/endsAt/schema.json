{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "allOf": [
        {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": false
        }
      ]
    },
    {
      "type": "array",
      "minItems": 2,
      "items": [
        {
          "const": "endsAt"
        },
        {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      ],
      "additionalItems": true,
      "errorMessage": {
        "items": "endsAt tag must start with 'endsAt' followed by a unix timestamp in seconds"
      }
    }
  ],
  "$id": "https://nostrability.github.io/schemata/tag/endsAt.json"
}