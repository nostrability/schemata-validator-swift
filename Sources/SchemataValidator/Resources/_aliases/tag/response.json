{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 2,
          "items": [
            {
              "const": "response"
            },
            {
              "type": "string",
              "pattern": "^[A-Za-z0-9]+$"
            }
          ],
          "additionalItems": true,
          "errorMessage": {
            "items": "response tag must be ['response', '<alphanumeric option id>']"
          }
        }
      ]
    }
  ]
}