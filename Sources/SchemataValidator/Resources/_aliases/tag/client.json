{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 4,
          "items": [
            {
              "const": "client"
            },
            {
              "title": "name",
              "type": "string",
              "minLength": 1
            },
            {
              "title": "handler_address",
              "type": "string",
              "pattern": "^31990:[a-f0-9]{64}:.+$"
            },
            {
              "title": "relay_hint",
              "type": "string",
              "pattern": "^(ws://|wss://).+$"
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}