{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": [
            {
              "const": "mls_protocol_version"
            },
            {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)*$",
              "description": "MLS protocol version identifier"
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}