{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "description": "Image dimensions in the form <width>x<height>",
          "minItems": 2,
          "items": [
            {
              "const": "dim"
            },
            {
              "type": "string",
              "pattern": "^\\d+x\\d+$"
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}