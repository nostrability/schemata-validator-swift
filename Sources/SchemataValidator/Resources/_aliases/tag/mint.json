{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": [
            {
              "const": "mint"
            },
            {
              "type": "string",
              "pattern": "^https?://.+$"
            },
            {
              "type": "string"
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}